---
import { languages, useTranslations, defaultLang, getRelativeLocaleUrl } from '../i18n/utils';
// Utilizamos Astro Image para optimización nativa y mejor rendimiento
import { Image } from 'astro:assets';
import heroBg from '../assets/hero-bg.jpg';

const [, langParam] = Astro.url.pathname.split('/');
const currentLang = Object.keys(languages).includes(langParam) ? langParam : defaultLang;
const t = await useTranslations(currentLang as keyof typeof languages);
---

<section class="hero-section" aria-label="Hero">
  <!-- Contenedor del fondo con capa superpuesta para contraste WCAG AA -->
  <div class="hero-bg-container" aria-hidden="true">
    <Image 
      src={heroBg} 
      alt="" 
      class="hero-bg-img"
      format="webp"
      quality="80"
    />
    <!-- Overlay: Midnight (#0B132B) al 65% -->
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <h1 class="hero-title">{t('hero', 'title')}</h1>
    <span class="hero-date">{t('hero', 'date')}</span>
    <a href={getRelativeLocaleUrl(currentLang, '/programacion')} class="hero-cta-btn">{t('hero', 'cta')}</a>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-offwhite);
    color: var(--color-midnight);
    overflow: hidden;
  }

  .hero-bg-container {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0.4;
    filter: grayscale(30%);
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 70%;
    background: linear-gradient(to top, var(--color-offwhite) 0%, rgba(248,249,250,0.8) 40%, transparent 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 900px;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-date {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.15em;
    margin-top: var(--space-sm);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5.5rem);
    color: var(--color-midnight);
    margin: 0;
    line-height: 1.1;
    font-weight: 400;
  }

  .hero-cta-btn {
    display: inline-block;
    background-color: var(--color-gold, #C5A059);
    color: #FFFFFF;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.1rem;
    padding: 16px 36px;
    border-radius: var(--border-radius);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    margin-top: var(--space-lg);
  }

  .hero-cta-btn:hover,
  .hero-cta-btn:focus-visible {
    background-color: #FFFFFF; /* Efecto brillo */
    color: var(--color-midnight);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
    outline: none;
  }
</style>
