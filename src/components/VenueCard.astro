---
import { Image } from 'astro:assets';

export interface Props {
  name: string;
  description: string;
  image: string;
  imageAlt: string;
  slug: string;
}

const { name, description, image, imageAlt, slug } = Astro.props;

// Vite glob for dynamic image resolution
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/venue_images/*.{jpeg,jpg,JPG,JPEG,png,gif,webp}');
const imagePath = `../assets/venue_images/${image}`;
const imageSrc = images[imagePath] ? images[imagePath]() : null;
---

<article class="venue-card">
  <div class="venue-media">
    {imageSrc ? (
      <Image 
        src={imageSrc} 
        alt={imageAlt} 
        class="venue-img"
        format="webp"
        quality="85"
      />
    ) : (
      <div class="venue-img-placeholder"></div>
    )}
  </div>
  
  <div class="venue-content">
    <h3 class="venue-title">{name}</h3>
    <p class="venue-desc">{description}</p>
  </div>
</article>

<style>
  .venue-card {
    display: flex;
    flex-direction: column;
    background-color: transparent;
    border: none;
    height: 100%;
    overflow: hidden;
  }

  .venue-media {
    width: 100%;
    overflow: hidden;
    background-color: var(--color-midnight, #0B132B);
    margin-bottom: var(--space-md);
    border-radius: var(--border-radius, 8px);
  }

  .venue-img {
    width: 100%;
    height: auto;
    max-height: 50vh;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .venue-card:hover .venue-img {
    transform: scale(1.03);
  }

  .venue-img-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-midnight);
    opacity: 0.8;
  }

  .venue-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .venue-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-midnight, #0B132B);
    margin: 0 0 var(--space-xs) 0;
    line-height: 1.3;
  }

  .venue-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-midnight, #0B132B);
    opacity: 0.75;
    margin: 0 0 var(--space-md) 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
