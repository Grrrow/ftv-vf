---
import { Image } from 'astro:assets';
import { useTranslations, languages, defaultLang } from '../i18n/utils';

export interface Props {
  id: string;
  fecha: string;
  slug: string;
  lugar: string;
  imagenUrl: string;
  taylorTicketsUrl: string;
  titulo: string;
  interpretes: string;
  sinopsisCorta: string;
  ctaText: string;
}

const { id, fecha, slug, lugar, imagenUrl, taylorTicketsUrl, titulo, interpretes, sinopsisCorta, ctaText } = Astro.props;

const [, langParam] = Astro.url.pathname.split('/');
const currentLocale = Object.keys(languages).includes(langParam) ? langParam : defaultLang;
const t = await useTranslations(currentLocale as keyof typeof languages);

// Vite glob for dynamic image resolution
const images = import.meta.glob<{ default: ImageMetadata }>('../assets/events_images/*.{jpeg,jpg,png,gif,webp}');
const imagePath = `../assets/events_images/${imagenUrl}`;
const imageSrc = images[imagePath] ? images[imagePath]() : null;

// Format date
const dateObj = new Date(fecha);
const formatterDate = new Intl.DateTimeFormat(Astro.currentLocale || 'es', { month: 'short', day: 'numeric' });
const formatterTime = new Intl.DateTimeFormat(Astro.currentLocale || 'es', { hour: '2-digit', minute: '2-digit' });

const dateString = formatterDate.format(dateObj).toUpperCase();
const timeString = formatterTime.format(dateObj) + 'h';
---

<article class="event-card">
  <div class="card-media">
    {imageSrc ? (
      <Image 
        src={imageSrc} 
        alt={titulo} 
        class="card-img"
        format="webp"
        quality="85"
        widths={[400, 800]}
        sizes="(max-width: 768px) 100vw, 400px"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="card-img-placeholder"></div>
    )}
    <div class="card-date-badge">
      <span class="badge-date">{dateString}</span>
      <span class="badge-time">{timeString}</span>
    </div>
  </div>
  
  <div class="card-content">
    <div class="card-location">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      {lugar}
    </div>
    <h3 class="card-title">
      <a href={`/${Astro.currentLocale || 'es'}/evento/${slug}`} class="event-link" title={`Ver detalles de ${titulo}`}>
        {titulo}
      </a>
    </h3>
    <p class="card-performer">{interpretes}</p>
    
    <p class="card-synopsis">{sinopsisCorta}</p>
  </div>
  
  <div class="card-footer">
    <div class="cta-wrapper">
      <span class="card-cta disabled" aria-disabled="true" title={t('tickets', 'soon')}>
        {ctaText}
      </span>
      <p class="cta-soon-text">{t('tickets', 'soon')}</p>
    </div>
  </div>
</article>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface, #FFFFFF);
    border: 1px solid var(--color-border);
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .event-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(11, 19, 43, 0.08);
  }

  .card-media {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background-color: var(--color-midnight, #0B132B);
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.1);
    transition: filter 0.5s ease, transform 0.5s ease;
  }

  .event-card:hover .card-img {
    filter: grayscale(40%) contrast(1.1);
    transform: scale(1.03);
  }
  
  .card-img-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-midnight);
    opacity: 0.8;
  }

  .card-date-badge {
    position: absolute;
    top: 0;
    left: 0;
    background-color: var(--color-offwhite, #F8F9FA);
    padding: 12px 16px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge-date {
    font-family: var(--font-heading);
    color: var(--color-midnight, #0B132B);
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .badge-time {
    color: var(--color-midnight, #0B132B);
    opacity: 0.7;
    font-size: 0.85rem;
  }

  .card-content {
    padding: var(--space-xl);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .card-location {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--color-midnight);
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .card-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--color-midnight, #0B132B);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .card-performer {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-midnight, #0B132B);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
    margin: 0 0 var(--space-md) 0;
  }

  .card-synopsis {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-midnight, #0B132B);
    opacity: 0.75;
    margin: 0;
  }

  .card-footer {
    padding: 0 var(--space-xl) var(--space-xl);
    margin-top: auto;
  }

  .event-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .event-link:hover {
    color: var(--color-midnight);
    text-decoration: underline;
    text-decoration-color: var(--color-gold);
    text-underline-offset: 4px;
  }

  .card-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background-color: var(--color-midnight, #0B132B);
    color: var(--color-offwhite, #F8F9FA);
    border: 1px solid var(--color-midnight, #0B132B);
    padding: 14px 16px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    text-align: center;
    white-space: normal;
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
    line-height: 1.3;
  }

  .card-cta:not(.disabled):hover,
  .card-cta:not(.disabled):focus-visible {
    background-color: transparent;
    color: var(--color-midnight, #0B132B);
  }

  .card-cta.disabled {
    background-color: var(--color-border);
    color: var(--color-midnight);
    border-color: var(--color-border);
    cursor: not-allowed;
    opacity: 0.5;
  }

  .cta-soon-text {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text);
    font-style: italic;
    margin-top: var(--space-xs);
    margin-bottom: 0;
  }
</style>
