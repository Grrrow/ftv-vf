---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  lang: string;
  image?: string;
  type?: string;
}

const { 
  title, 
  description, 
  lang,
  image = '/og-artists.jpg',
  type = 'website'
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://musicaenvillafranca.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const imageUrl = new URL(image, siteUrl).href;

// Logic to clean the current pathname and swap the language prefix
const getAltUrl = (targetLang: string) => {
  let path = Astro.url.pathname;
  // Remove existing lang prefix if it exists
  path = path.replace(/^\/(es|en|de)/, '');
  if (!path.startsWith('/')) path = '/' + path;
  return new URL(`/${targetLang}${path}`, siteUrl).href;
};
---

<!-- SEO Global -->
<ClientRouter fallback="swap" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="canonical" href={canonicalUrl} />
<meta name="thumbnail" content={imageUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<!-- i18n Alternates -->
<link rel="alternate" hreflang="es" href={getAltUrl('es')} />
<link rel="alternate" hreflang="en" href={getAltUrl('en')} />
<link rel="alternate" hreflang="de" href={getAltUrl('de')} />
<link rel="alternate" hreflang="x-default" href={getAltUrl('es')} />

<!-- Schema.org / JSON-LD para Eventos -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Festival",
  "name": "Música en Villafranca",
  "description": description,
  "url": siteUrl,
  "image": imageUrl,
  "startDate": "2026-07-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Villafranca del Bierzo",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Villafranca del Bierzo",
      "addressRegion": "León",
      "addressCountry": "ES"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Asociación Cultural Marita Caro Carvajal"
  },
  "director": {
    "@type": "Person",
    "name": "Pedro Halffter Caro",
    "jobTitle": "Director Artístico"
  }
})} />

<script>
  // Add scroll reveal animations using Intersection Observer
  // Works with Astro View Transitions
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // Optionally unobserve after revealing to animate only once:
          observer.unobserve(entry.target);
        }
      });
    }, { 
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px"
    });

    // Select elements that should animate on scroll
    const hiddenElements = document.querySelectorAll(`
      .animate-on-scroll, 
      section h2.section-title, 
      .event-card-horizontal, 
      .venue-card, 
      .manifesto-text p,
      .program-header,
      .hero-content,
      .program-hero-container
    `);
    
    hiddenElements.forEach((el) => {
      // Add the hidden class to set initial CSS state
      el.classList.add('reveal-hidden');
      observer.observe(el);
    });
  });
</script>
