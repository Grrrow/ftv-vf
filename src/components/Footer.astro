---
import { languages, useTranslations, defaultLang } from '../i18n/utils';

const [, langParam] = Astro.url.pathname.split('/');
const currentLang = Object.keys(languages).includes(langParam) ? langParam : defaultLang;
const t = await useTranslations(currentLang as keyof typeof languages);
---

<footer role="contentinfo" class="site-footer">
  <div class="footer-content">
    <div class="footer-contact">
      <h3>{currentLang === 'es' ? 'Contacto' : currentLang === 'en' ? 'Contact' : 'Kontakt'}</h3>
      <a href="mailto:info@musicaenvillafranca.com" class="footer-email" aria-label="Enviar un correo electrónico a info@musicaenvillafranca.com">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="email-icon" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
        <span>info@musicaenvillafranca.com</span>
      </a>
    </div>
    <div class="footer-bottom">
      <p>{t('footer', 'copyright')}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-xxl);
    background-color: var(--color-surface);
    color: var(--color-midnight);
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .footer-contact h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-midnight);
  }

  .footer-email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-midnight);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .footer-email:hover {
    opacity: 0.8;
  }

  .email-icon {
    color: var(--color-gold);
  }

  .footer-bottom {
    font-size: 0.9rem;
    opacity: 0.7;
    border-top: 1px solid rgba(11, 19, 43, 0.05);
    width: 100%;
    padding-top: var(--space-md);
    margin-top: var(--space-sm);
  }

  .footer-bottom p {
    margin: 0;
  }
</style>
