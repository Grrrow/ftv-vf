---
import { languages, useTranslations, defaultLang } from '../i18n/utils';

const [, langParam] = Astro.url.pathname.split('/');
const currentLang = Object.keys(languages).includes(langParam) ? langParam : defaultLang;
const t = await useTranslations(currentLang as keyof typeof languages);
---

<footer role="contentinfo" class="site-footer">
  <div class="footer-content">
    <div class="footer-contact">
      <h3>{currentLang === 'es' ? 'Contacto' : currentLang === 'en' ? 'Contact' : 'Kontakt'}</h3>
      <a href="tel:+34600000000" class="footer-phone" aria-label="Llamar al teléfono de contacto +34 600 000 000">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="phone-icon" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>+34 600 000 000</span>
      </a>
    </div>
    <div class="footer-bottom">
      <p>{t('footer', 'copyright')}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-xl) var(--space-md);
    text-align: center;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-xxl);
    background-color: var(--color-surface);
    color: var(--color-midnight);
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .footer-contact h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-midnight);
  }

  .footer-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-midnight);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 1.15rem;
    font-weight: 500;
    transition: opacity 0.2s ease;
  }

  .footer-phone:hover {
    opacity: 0.8;
  }

  .phone-icon {
    color: var(--color-gold);
  }

  .footer-bottom {
    font-size: 0.9rem;
    opacity: 0.7;
    border-top: 1px solid rgba(11, 19, 43, 0.05);
    width: 100%;
    padding-top: var(--space-md);
    margin-top: var(--space-sm);
  }

  .footer-bottom p {
    margin: 0;
  }
</style>
