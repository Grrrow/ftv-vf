---
import { languages, useTranslations, defaultLang } from "../../i18n/utils";
import SEO from "../../components/SEO.astro";
import SkipLink from "../../components/SkipLink.astro";
import "../../styles/global.css";

import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import Manifesto from "../../components/Manifesto.astro";
import ProgramTeaser from "../../components/ProgramTeaser.astro";
import VenuesSection from "../../components/VenuesSection.astro";
import MapSection from "../../components/MapSection.astro";
import Footer from "../../components/Footer.astro";
import VideoCarousel from "../../components/VideoCarousel.astro";
import Sponsors from "../../components/Sponsors.astro";

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang: lang === defaultLang ? undefined : lang },
  }));
}

const { lang } = Astro.params || "es";
const currentLang = Object.keys(languages).includes(lang as string)
  ? lang
  : defaultLang;
const t = await useTranslations(currentLang as keyof typeof languages);
---

<!doctype html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={t("seo", "title")}
      description={t("seo", "description")}
      lang={lang}
    />
  </head>
  <body>
    <SkipLink />
    <Header />

    <main id="main-content" role="main">
      <Hero />
      <Manifesto />
      <ProgramTeaser />
      <VenuesSection />
      <VideoCarousel />
      <MapSection />
      <Sponsors />
    </main>

    <Footer />
  </body>
</html>
