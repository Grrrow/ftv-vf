---
import { languages, useTranslations, defaultLang } from '../../i18n/utils';
import { Image } from 'astro:assets';
import Header from '../../components/Header.astro';
import SkipLink from '../../components/SkipLink.astro';
import SEO from '../../components/SEO.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

import maritaImage from '../../assets/marita&cristobal.jpg';
import pedroImage from '../../assets/pedrohalffter.jpg';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({
    params: { lang: lang === defaultLang ? undefined : lang }
  }));
}

const { lang } = Astro.params;
const currentLang = Object.keys(languages).includes(lang as string) ? lang : defaultLang;
const t = await useTranslations(currentLang as keyof typeof languages);

const videos = [
  { id: "FNSjNbxarX4", titleKey: "video_1_title" },
  { id: "1KKL87bpvuQ", titleKey: "video_2_title" },
  { id: "cCAnWrmSSyY", titleKey: "video_3_title" },
  { id: "dq4BFts8bvk", titleKey: "video_4_title" },
  { id: "4RLE53jG_PU", titleKey: "video_5_title" },
  { id: "hhtVvEj7GYM", titleKey: "video_6_title" },
  { id: "LrrQgQpVCLo", titleKey: "video_7_title" },
  { id: "Osp_un1xQco", titleKey: "video_8_title" }
];
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO 
      title={`El Festival | ${t('seo', 'title')}`}
      description="El Origen de un Sueño Musical y Místico en Villafranca del Bierzo."
      lang={lang as string}
    />
  </head>
  <body>
    <SkipLink />
    <Header />
    
    <main id="main-content" role="main" class="festival-page">
      
      <!-- 1. SECCIÓN HERO / CABECERA -->
      <section class="festival-hero" aria-labelledby="hero-title">
        <div class="hero-bg"></div>
        <div class="hero-content">
          <p class="hero-pretitle">{t('manifesto', 'hero_pretitle')}</p>
          <h1 id="hero-title" class="hero-title" set:html={t('manifesto', 'hero_title')} />
          <p class="hero-intro">
            {t('manifesto', 'hero_intro')}
          </p>
        </div>
      </section>

      <!-- 2. BLOQUE: EL PORQUÉ DEL FESTIVAL -->
      <section class="festival-why" aria-labelledby="why-title">
        <div class="why-container">
          <div class="why-left">
            <h2 id="why-title" class="section-title">{t('manifesto', 'why_title')}</h2>
            <div class="accent-line"></div>
          </div>
          <div class="why-right">
            <div class="why-block">
              <p>{t('manifesto', 'why_p1')}</p>
            </div>
            <div class="why-block why-block-offset">
              <p set:html={t('manifesto', 'why_p2')} />
            </div>
          </div>
        </div>
      </section>

      <!-- 2.5. BLOQUE: HOMENAJE -->
      <section class="festival-tribute">
        <div class="tribute-container">
          <div class="tribute-image-wrapper">
            <Image src={maritaImage} alt="Marita Caro y Cristóbal Halffter" class="tribute-image" width={800} />
          </div>
          <div class="tribute-content">
            <h2 class="tribute-title">{t('manifesto', 'tribute_title')}</h2>
            <p class="tribute-text">{t('manifesto', 'tribute_text')}</p>
          </div>
        </div>
      </section>

      <!-- 2.6. BLOQUE: DIRECTOR ARTÍSTICO -->
      <section class="festival-tribute festival-director">
        <div class="tribute-container tribute-container--reverse">
          <div class="tribute-image-wrapper">
            <Image src={pedroImage} alt="Pedro Halffter Caro" class="tribute-image" width={800} />
          </div>
          <div class="tribute-content">
            <h2 class="tribute-title">{t('manifesto', 'director_title')}</h2>
            <p class="tribute-text tribute-text--long" set:html={t('manifesto', 'director_text')} />
          </div>
        </div>
      </section>

      <!-- 3. BLOQUE: CALLOUT / VISION -->
      <section class="festival-callout">
        <div class="callout-container">
          <div class="accent-line-vertical"></div>
          <blockquote class="callout-text">
            "{t('manifesto', 'callout')}"
          </blockquote>
        </div>
      </section>

      <!-- 4. BLOQUE: NUESTRA MISIÓN -->
      <section class="festival-mission" aria-labelledby="mission-title">
        <div class="mission-container">
          <h2 id="mission-title" class="sr-only">{t('manifesto', 'mission_title')}</h2>
          <div class="mission-grid">
            <article class="mission-card">
              <h3 class="mission-card-title">{t('manifesto', 'mission_1_title')}</h3>
              <p class="mission-card-text">{t('manifesto', 'mission_1_text')}</p>
            </article>
            <article class="mission-card">
              <h3 class="mission-card-title">{t('manifesto', 'mission_2_title')}</h3>
              <p class="mission-card-text">{t('manifesto', 'mission_2_text')}</p>
            </article>
            <article class="mission-card">
              <h3 class="mission-card-title">{t('manifesto', 'mission_3_title')}</h3>
              <p class="mission-card-text">{t('manifesto', 'mission_3_text')}</p>
            </article>
          </div>
        </div>
      </section>

      <!-- 5. SECCIÓN: VIDEOS EDICIONES ANTERIORES -->
      <section class="festival-memory" aria-labelledby="memory-title">
        <div class="memory-container">
          <div class="memory-header">
            <h2 id="memory-title" class="section-title">{t('manifesto', 'memory_title')}</h2>
            <p class="memory-intro">{t('manifesto', 'memory_intro')}</p>
          </div>
          <div class="memory-grid">
            {videos.map((vid) => (
              <div class="video-card">
                <iframe width="100%" style="aspect-ratio: 16/9; border-radius: 4px 4px 0 0; display: block;" src={`https://www.youtube.com/embed/${vid.id}`} srcdoc={`<style>*{padding:0;margin:0;overflow:hidden}html,body{height:100%}img,span{position:absolute;width:100%;top:0;bottom:0;margin:auto;object-fit:cover;}span{height:1.5em;text-align:center;font:48px/1.5 sans-serif;color:#C5A059;text-shadow:0 0 0.5em #0B132B, 0 0 0.2em #0B132B;transition:transform 0.2s ease;}a:hover span{transform:scale(1.1);}</style><a href=https://www.youtube.com/embed/${vid.id}?autoplay=1><img src=https://img.youtube.com/vi/${vid.id}/hqdefault.jpg alt='Reproducir video' /><span>▶</span></a>`} title="Video edición anterior" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
                <div class="video-card-content">
                  <h3 class="video-card-title">{t('manifesto', vid.titleKey as any)}</h3>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

    </main>
    
    <Footer />
  </body>
</html>

<style>
  /* GLOBAL TO PAGE */
  .festival-page {
    background-color: #FDFBF7;
    color: #2A2C30;
    font-family: var(--font-body);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 400;
    color: #2A2C30;
    margin: 0 0 var(--space-md) 0;
  }

  .accent-line {
    width: 60px;
    height: 1px;
    background-color: #C5A059;
    margin: var(--space-sm) 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* 1. HERO */
  .festival-hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xxl) var(--space-md);
    background-color: #FDFBF7;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .festival-hero {
      padding: 120px var(--space-md);
    }
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #FDFBF7;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 1000px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .hero-pretitle {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: #2A2C30;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 600;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5rem);
    color: #2A2C30;
    margin: 0;
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .hero-intro {
    font-family: var(--font-body);
    font-size: 1.2rem;
    line-height: 1.8;
    max-width: 700px;
    margin: 0;
    color: #2A2C30;
    font-weight: 300;
  }

  /* 2. WHY */
  .festival-why {
    padding: var(--space-xxl) var(--space-md);
    background-color: transparent;
  }

  @media (min-width: 768px) {
    .festival-why {
      padding: 120px var(--space-md);
    }
  }

  .why-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 900px) {
    .why-container {
      grid-template-columns: 1fr 2fr;
      align-items: start;
    }
  }

  .why-left {
    position: relative;
    padding-right: var(--space-lg);
  }

  @media (min-width: 900px) {
    .why-left {
      border-right: 1px solid #C5A059;
      padding-bottom: 200px;
    }
  }

  .why-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  @media (min-width: 900px) {
    .why-right {
      gap: 120px;
    }
  }

  .why-block p {
    font-size: 1.15rem;
    line-height: 1.8;
    margin: 0;
    color: #2A2C30;
    font-weight: 300;
  }

  /* 2.5. HOMENAJE */
  .festival-tribute {
    padding: var(--space-xl) var(--space-md);
    background-color: #FDFBF7;
  }

  .tribute-container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    align-items: center;
  }

  /* Para el director, fondo diferente para separar las secciones sutilmente */
  .festival-director {
    background-color: #f7f5f0;
  }

  @media (min-width: 768px) {
    .festival-tribute {
      padding: 100px var(--space-md);
    }
    .tribute-container {
      flex-direction: row;
      gap: 80px;
    }
    .tribute-container--reverse {
      flex-direction: row-reverse;
    }
  }

  .tribute-image-wrapper {
    flex: 1;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    position: relative;
  }

  .tribute-image-wrapper::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border: 1px solid rgba(197, 160, 89, 0.3);
    border-radius: 8px;
    pointer-events: none;
  }

  .tribute-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .tribute-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .tribute-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.5rem);
    color: #2A2C30;
    margin-bottom: var(--space-md);
    line-height: 1.2;
    font-weight: 400;
  }

  .tribute-text {
    font-size: 1.15rem;
    line-height: 1.8;
    color: #2A2C30;
    opacity: 0.85;
  }

  /* Reducimos un poco la fuente si el texto es largo como en la bio */
  .tribute-text--long {
    font-size: 1.05rem;
  }

  @media (min-width: 900px) {
    .why-block-offset {
      padding-left: 100px;
    }
  }

  /* 3. CALLOUT */
  .festival-callout {
    padding: 0 var(--space-md) var(--space-xxl);
    background-color: transparent;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .festival-callout {
      padding: 0 var(--space-md) 120px;
    }
  }

  .callout-container {
    max-width: 800px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .accent-line-vertical {
    width: 1px;
    height: 40px;
    background-color: #C5A059;
  }

  @media (min-width: 768px) {
    .accent-line-vertical {
      height: 80px;
    }
  }

  .callout-text {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: #2A2C30;
    margin: 0;
    font-style: italic;
    line-height: 1.4;
    font-weight: 400;
  }

  /* 4. MISSION */
  .festival-mission {
    padding: var(--space-xxl) var(--space-md);
    background-color: #f7f4ee;
  }

  @media (min-width: 768px) {
    .festival-mission {
      padding: 120px var(--space-md);
    }
  }

  .mission-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .mission-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .mission-card {
    background-color: #FDFBF7;
    padding: var(--space-xl);
    border: 1px solid #C5A059;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.4s ease;
  }

  .mission-card:hover {
    transform: translateY(-5px);
  }

  .mission-card-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: #2A2C30;
    margin: 0 0 var(--space-md) 0;
    font-weight: 400;
  }

  .mission-card-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #2A2C30;
    opacity: 0.85;
    margin: 0;
    font-weight: 300;
  }

  /* 5. VISUAL MEMORY */
  .festival-memory {
    padding: var(--space-xxl) var(--space-md);
    background-color: #FDFBF7;
  }

  @media (min-width: 768px) {
    .festival-memory {
      padding: 120px var(--space-md);
    }
  }

  .memory-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .memory-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .memory-intro {
    font-size: 1.1rem;
    color: #2A2C30;
    font-style: italic;
    opacity: 0.8;
    margin: 0;
  }

  .memory-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-lg);
  }

  .video-card {
    width: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 12px rgba(11, 19, 43, 0.04);
    border-radius: 4px;
    background-color: transparent;
    transition: transform 0.3s ease;
    height: 100%;
  }

  .video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(197, 160, 89, 0.1);
  }

  .video-card-content {
    padding: var(--space-sm) var(--space-xs);
    background-color: transparent;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .video-card-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: #0B132B;
    margin: 0;
    font-weight: 500;
    text-align: center;
    line-height: 1.4;
  }

  @media (min-width: 768px) {
    .video-card {
      width: calc(33.333% - (var(--space-lg) * 2 / 3));
    }
  }
</style>
