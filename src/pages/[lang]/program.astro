---
import { languages, useTranslations } from '../../i18n/utils';
import SEO from '../../components/SEO.astro';
import SkipLink from '../../components/SkipLink.astro';
import '../../styles/global.css';

import Header from '../../components/Header.astro';
import ProgramItem from '../../components/ProgramItem.astro';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = await useTranslations(lang as keyof typeof languages);

// Get the actual data collection for array elements (events)
const allEvents = await getCollection('events');
const events = allEvents
  .filter(event => event.id.startsWith(`${lang}/`))
  .map(event => event.data);
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO 
      title={`${t('nav', 'program')} | ${t('seo', 'title')}`}
      description={t('seo', 'description')}
      lang={lang}
    />
  </head>
  <body>
    <SkipLink />
    <Header />
    
    <main id="main-content" role="main">
      <section class="page-header" aria-labelledby="page-title">
        <div class="header-container">
          <h1 id="page-title" class="page-title">{t('nav', 'program')}</h1>
          <p class="page-desc">{t('program_teaser', 'description')}</p>
        </div>
      </section>

      <section class="program-full-section">
        <div class="program-container">
          <div class="program-list">
            {events.map((event) => (
              <ProgramItem {...event} />
            ))}
          </div>
        </div>
      </section>
    </main>
    
    <footer role="contentinfo" style="padding: var(--space-lg); text-align: center; border-top: 1px solid var(--color-border); margin-top: var(--space-xxl); background-color: var(--color-surface);">
      <p style="margin: 0; font-size: 0.9rem; opacity: 0.7;">{t('footer', 'copyright')}</p>
    </footer>
  </body>
</html>

<style>
  .page-header {
    background-color: var(--color-offwhite);
    padding: var(--space-xxl) var(--space-md) var(--space-xl);
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }

  .header-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--color-midnight);
    margin: 0 0 var(--space-sm) 0;
    font-weight: 600;
  }

  .page-desc {
    font-size: 1.2rem;
    color: var(--color-text);
    opacity: 0.8;
  }

  .program-full-section {
    background-color: var(--color-surface);
    padding: var(--space-xl) var(--space-md) var(--space-xxl);
  }

  .program-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .program-list {
    display: flex;
    flex-direction: column;
  }
</style>
